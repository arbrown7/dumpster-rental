<%# partials/rental-card.ejs %>
<%# Expected locals: rental (object) %>

<div class="col-12 col-md-6 col-lg-4">
  <div class="card border-0 shadow-sm h-100">
    <div class="card-body p-4">

      <%# Status Badge %>
      <%
        const statusMap = {
          pending:   { cls: 'warning',   icon: 'clock',        label: 'Pending' },
          active:    { cls: 'primary',   icon: 'play-circle',  label: 'Active' },
          completed: { cls: 'success',   icon: 'check-circle', label: 'Completed' },
          cancelled: { cls: 'danger',    icon: 'x-circle',     label: 'Cancelled' }
        };
        const s = statusMap[rental.status] || { cls: 'secondary', icon: 'question-circle', label: rental.status };
      %>
      <div class="d-flex justify-content-between align-items-start mb-3">
        <span class="badge text-bg-<%= s.cls %>">
          <i class="bi bi-<%= s.icon %> me-1"></i><%= s.label %>
        </span>
        <% if (rental.paid) { %>
          <span class="badge text-bg-success">
            <i class="bi bi-check-lg me-1"></i>Paid
          </span>
        <% } else { %>
          <span class="badge text-bg-danger">
            <i class="bi bi-x-lg me-1"></i>Unpaid
          </span>
        <% } %>
      </div>

      <%# Size %>
      <h6 class="fw-bold mb-1"><%= rental.size %> Dumpster</h6>

      <%# Address %>
      <p class="text-muted small mb-2">
        <i class="bi bi-geo-alt me-1"></i><%= rental.address %>
      </p>

      <%# Dates %>
      <div class="d-flex gap-3 text-muted small mb-3">
        <span><i class="bi bi-truck me-1"></i><%= rental.deliveryDate %></span>
        <span><i class="bi bi-calendar-check me-1"></i><%= rental.pickupDate %></span>
      </div>

    </div>

    <div class="card-footer bg-transparent border-0 px-4 pb-3">
      <a href="/rental/<%= rental.id %>/confirmation" class="btn btn-sm btn-outline-secondary w-100">
        <i class="bi bi-eye me-1"></i>View Details
      </a>
    </div>

  </div>
</div>
