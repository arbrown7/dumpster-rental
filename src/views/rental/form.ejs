<%- include('../partials/header') %>
<% if (typeof errors !== 'undefined' && errors.length > 0) { %>
  <div class="alert alert-danger" role="alert">
    <% errors.forEach(function(error) { %>
      <div><i class="bi bi-exclamation-triangle me-1"></i><%= error.msg %></div>
    <% }); %>
  </div>
<% } %>
    <div class="bg-light rental-form-page">
        <div class="container py-5">
            <div class="row justify-content-center">
                <div class="col-12 col-lg-8">
                    <div class="card shadow-sm">
                        <div class="card-body p-4">
                            <h1 class="h3 mb-4">Draper City Dumpster Rental</h1>

                            <form action="/rental" method="POST" class="vstack gap-3">
                                <div>
                                    <h2 class="h5">Dumpster Size</h2>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="size" id="size20"
                                            value="20yard" required>
                                        <label class="form-check-label" for="size20">20 Yard ($120)</label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="size" id="size30"
                                            value="30yard" required>
                                        <label class="form-check-label" for="size30">30 Yard ($150)</label>
                                    </div>
                                </div>

                                <div class="form-group">
                                    <h2 class="h5">Customer Information</h2>
                                    <label class="form-label" for="name">Full Name</label>
                                    <input class="form-control" type="text" id="name" name="name" required>
                                </div>
                                
                                <div class="form-group">
                                    <label class="form-label mt-3" for="phone">Phone Number</label>
                                    <input class="form-control" type="tel" id="phone" name="phone" required>
                                </div>
                                    
                                <div class="form-group">
                                    <label class="form-label mt-3" for="organization">Organization / Group (If
                                        Applicable)</label>
                                    <input class="form-control" type="text" id="organization" name="organization">
                                </div>

                                    
                                <div class="form-group">
                                    <label class="form-label mt-3" for="address">Delivery Address</label>
                                    <input class="form-control" type="text" id="address" name="address" required>
                                </div>

                                    
                                <div class="form-group">
                                    <label class="form-label mt-3" for="placement">Placement Instructions</label>
                                    <textarea class="form-control" id="placement" name="placement" rows="3" required></textarea>
                                </div>

                                <div class="form-group">
                                    <h2 class="h5">Scheduling</h2>
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label class="form-label" for="deliveryDate">Delivery Date</label>
                                            <input class="form-control" type="text" id="deliveryDate" name="deliveryDate" placeholder="Select a delivery date" readonly required />
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label" for="pickupDate">Scheduled Pickup Date</label>
                                            <input class="form-control" type="text" id="pickupDate" name="pickupDate" placeholder="Pickup date will appear here" readonly/>
                                        </div>
                                    </div>
                                </div>

                                <div class="alert alert-warning d-none" role="alert" id="schedule-warning">
                                    <strong>There are no dumpsters available in that size on your selected delivery date.</strong> 
                                    <p>Please select a different date or try a different size.</p>
                                </div>

                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="agreement" id="agreement" required>
                                    <label class="form-check-label" for="agreement">I understand dumpster rules and
                                        liability terms.</label>
                                </div>

                                <button class="btn btn-primary" type="submit" id="submitBtn">Submit Request</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <%- include('../partials/footer') %>