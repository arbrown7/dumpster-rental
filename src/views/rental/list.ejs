<%# rentals.ejs — reusable for all rentals, current rentals, and user rentals views %>
<%# Expected locals: rentals (array), title (string), emptyMessage (string, optional) %>
<%- include('../partials/header') %>
<div class="container py-4">

  <%# Page Header %>
  <div class="d-flex align-items-center justify-content-between mb-4">
    <div>
      <h2 class="fw-bold mb-0"><%= title %></h2>
      <p class="text-muted mb-0"><%= rentals.length %> rental<%= rentals.length !== 1 ? 's' : '' %> found</p>
    </div>
    <% if (typeof showNewButton !== 'undefined' && showNewButton) { %>
      <a href="/rental/new" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> New Rental
      </a>
    <% } %>
  </div>

  <%# Search & Filter (admin only) %>
  <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
    <%
      const f = typeof filters !== 'undefined' ? filters : {};
      const fSearch = f.search || '';
      const fStatus = f.status || '';
      const fPaid   = f.paid   || '';
      const fSize   = f.size   || '';
    %>
    <form method="GET" class="mb-4">
      <div class="row g-2 align-items-center">

        <div class="col-12 col-md-4">
          <div class="input-group">
            <span class="input-group-text bg-white border-end-0">
              <i class="bi bi-search text-muted"></i>
            </span>
            <input
              type="text"
              name="search"
              class="form-control border-start-0"
              placeholder="Search name, phone, address…"
              value="<%= fSearch %>"
            >
          </div>
        </div>

        <% if (typeof showStatusFilter === 'undefined' || showStatusFilter) { %>
          <div class="col-6 col-md-2">
            <select name="status" class="form-select">
              <option value="">All Statuses</option>
              <option value="pending"   <%= fStatus === 'pending'   ? 'selected' : '' %>>Pending</option>
              <option value="active"    <%= fStatus === 'active'    ? 'selected' : '' %>>Active</option>
              <option value="completed" <%= fStatus === 'completed' ? 'selected' : '' %>>Completed</option>
              <option value="cancelled" <%= fStatus === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
            </select>
          </div>
        <% } %>

        <% if (typeof showPaidFilter === 'undefined' || showPaidFilter) { %>
          <div class="col-6 col-md-2">
            <select name="paid" class="form-select">
              <option value="">All — Paid/Unpaid</option>
              <option value="true"  <%= fPaid === 'true'  ? 'selected' : '' %>>Paid</option>
              <option value="false" <%= fPaid === 'false' ? 'selected' : '' %>>Unpaid</option>
            </select>
          </div>
        <% } %>

        <div class="col-6 col-md-2">
          <select name="size" class="form-select">
            <option value="">All Sizes</option>
            <option value="20yard" <%= fSize === '20yard' ? 'selected' : '' %>>20 Yard</option>
            <option value="30yard" <%= fSize === '30yard' ? 'selected' : '' %>>30 Yard</option>
          </select>
        </div>

        <div class="col-6 col-md-2 d-flex gap-2">
          <button type="submit" class="btn btn-primary flex-grow-1">
            <i class="bi bi-funnel me-1"></i>Filter
          </button>
          <a href="<%= typeof clearFiltersUrl !== 'undefined' ? clearFiltersUrl : '/rental/all' %>" class="btn btn-outline-secondary" title="Clear filters">
            <i class="bi bi-x-lg"></i>
          </a>
        </div>

      </div>
    </form>
  <% } %>

  <%# Empty State %>
  <% if (!rentals || rentals.length === 0) { %>
    <div class="text-center py-5 text-muted">
      <i class="bi bi-inbox fs-1 d-block mb-3"></i>
      <p class="fs-5"><%= typeof emptyMessage !== 'undefined' ? emptyMessage : 'No rentals found.' %></p>
    </div>

  <%# Rentals Table %>
  <% } else { %>
    <div class="card shadow-sm border-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th scope="col">Customer</th>
              <th scope="col">Address</th>
              <th scope="col">Size</th>
              <th scope="col">Delivery</th>
              <th scope="col">Pickup</th>
              <th scope="col">Status</th>
              <th scope="col">Paid</th>
              <th scope="col" class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% rentals.forEach(function(rental) { %>
              <tr>

                <%# Customer Info %>
                <td>
                  <div class="fw-semibold"><%= rental.name %></div>
                  <div class="text-muted small"><%= rental.organization %></div>
                  <div class="text-muted small">
                    <i class="bi bi-telephone me-1"></i><%= rental.phone %>
                  </div>
                </td>

                <%# Address & Placement %>
                <td>
                  <div><%= rental.address %></div>
                  <% if (rental.placement) { %>
                    <div class="text-muted small">
                      <i class="bi bi-geo-alt me-1"></i><%= rental.placement %>
                    </div>
                  <% } %>
                </td>

                <%# Dumpster Size %>
                <td>
                  <span class="badge bg-secondary"><%= rental.size %></span>
                </td>

                <%# Delivery Date %>
                <td>
                  <% if (rental.deliveryDate) { %>
                    <i class="bi bi-truck me-1 text-muted"></i><%= rental.deliveryDate %>
                  <% } else { %>
                    <span class="text-muted">—</span>
                  <% } %>
                </td>

                <%# Pickup Date %>
                <td>
                  <% if (rental.pickupDate) { %>
                    <i class="bi bi-calendar-check me-1 text-muted"></i><%= rental.pickupDate %>
                  <% } else { %>
                    <span class="text-muted">—</span>
                  <% } %>
                </td>

                <%# Status Badge %>
                <td>
                  <%
                    const statusMap = {
                      pending:   { cls: 'warning',   icon: 'clock',         label: 'Pending' },
                      active:    { cls: 'primary',   icon: 'play-circle',   label: 'Paid' },
                      completed: { cls: 'success',   icon: 'check-circle',  label: 'Completed' },
                      cancelled: { cls: 'danger',    icon: 'x-circle',      label: 'Cancelled' }
                    };
                    const s = statusMap[rental.status] || { cls: 'secondary', icon: 'question-circle', label: rental.status };
                  %>
                  <span class="badge text-bg-<%= s.cls %>">
                    <i class="bi bi-<%= s.icon %> me-1"></i><%= s.label %>
                  </span>
                </td>

                <%# Paid Badge %>
                <td>
                  <% if (rental.paid) { %>
                    <span class="badge text-bg-success">
                      <i class="bi bi-check-lg me-1"></i>Paid
                    </span>
                  <% } else { %>
                    <span class="badge text-bg-danger">
                      <i class="bi bi-x-lg me-1"></i>Unpaid
                    </span>
                  <% } %>
                </td>

                <%# Actions %>
                <td class="text-end">
                  <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
                    <a href="/rental/<%= rental.id %>/edit" class="btn btn-sm btn-outline-primary" title="Edit">
                      Edit
                    </a>
                  <% } %>
                </td>

              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>

</div>
<%- include('../partials/footer') %>
