<%# rentals.ejs — reusable for all rentals, current rentals, and user rentals views %>
<%# Expected locals: rentals (array), title (string), emptyMessage (string, optional) %>
<%- include('../partials/header') %>
<div class="container py-4">
  <%
    const formatTableDate = (value) => {
      if (!value) return '—';
      if (typeof value === 'string') return value.length >= 5 ? value.slice(5) : value;
      if (typeof value.toDate === 'function') {
        return value.toDate().toISOString().split('T')[0].slice(5);
      }
      return String(value);
    };
  %>

  <%# Page Header %>
  <div class="d-flex align-items-center justify-content-between mb-4">
    <div>
      <h2 class="fw-bold mb-0"><%= title %></h2>
      <!-- <p class="text-muted mb-0"><%= rentals.length %> rental<%= rentals.length !== 1 ? 's' : '' %> found</p> -->
    </div>
    <% if (typeof showNewButton !== 'undefined' && showNewButton) { %>
      <a href="/rental/new" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> New Rental
      </a>
    <% } %>
  </div>

  <%# Empty State %>
  <% if (!rentals || rentals.length === 0) { %>
    <div class="text-center py-5 text-muted">
      <i class="bi bi-inbox fs-1 d-block mb-3"></i>
      <p class="fs-5"><%= typeof emptyMessage !== 'undefined' ? emptyMessage : 'No rentals found.' %></p>
    </div>

  <%# Rentals Table %>
  <% } else { %>
    <% if (typeof enableRowSearch !== 'undefined' && enableRowSearch) { %>
      <input type="text" id="rentalSearch" class="form-control mb-3" placeholder="Search by name or address..." />
    <% } %>
    <div class="card shadow-sm border-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th scope="col">
                <a href="?sort=name&order=<%= sort === 'name' && order === 'asc' ? 'desc' : 'asc' %>" 
                  class="text-decoration-none <%= sort === 'name' ? 'text-primary fw-semibold' : 'text-reset' %>">
                  Customer <i class="bi bi-arrow-<%= sort === 'name' ? (order === 'asc' ? 'up' : 'down') : 'down-up' %>"></i>
                </a>
              </th>
              <th scope="col">Address</th>
              <th scope="col">
                <a href="?sort=size&order=<%= sort === 'size' && order === 'asc' ? 'desc' : 'asc' %>" 
                  class="text-decoration-none <%= sort === 'size' ? 'text-primary fw-semibold' : 'text-reset' %>">
                  Size <i class="bi bi-arrow-<%= sort === 'size' ? (order === 'asc' ? 'up' : 'down') : 'down-up' %>"></i>
                </a>
              </th>
              <th scope="col">
                <% if (isCurrent || isFuture) { %>
                  Delivery
                <% } else { %>
                  <a href="?sort=delivery&order=<%= sort === 'delivery' && order === 'asc' ? 'desc' : 'asc' %>" 
                  class="text-decoration-none <%= sort === 'delivery' ? 'text-primary fw-semibold' : 'text-reset' %>">
                  Delivery <i class="bi bi-arrow-<%= sort === 'delivery' ? (order === 'asc' ? 'up' : 'down') : 'down-up' %>"></i>
                  </a>
                <% } %>
              </th>
              <th scope="col">
              <% if (isCurrent || isFuture) { %>
                  Pickup
              <% } else { %>
                <a href="?sort=pickup&order=<%= sort === 'pickup' && order === 'asc' ? 'desc' : 'asc' %>" 
                  class="text-decoration-none <%= sort === 'pickup' ? 'text-primary fw-semibold' : 'text-reset' %>">
                  Pickup <i class="bi bi-arrow-<%= sort === 'pickup' ? (order === 'asc' ? 'up' : 'down') : 'down-up' %>"></i>
                </a>
              <% } %>
              </th>
              <th scope="col">
                <% if (isCurrent || isFuture) { %>
                  Status
                <% } else { %>
                  <a href="?sort=status&order=<%= sort === 'status' && order === 'asc' ? 'desc' : 'asc' %>" 
                    class="text-decoration-none <%= sort === 'status' ? 'text-primary fw-semibold' : 'text-reset' %>">
                    Status <i class="bi bi-arrow-<%= sort === 'status' ? (order === 'asc' ? 'up' : 'down') : 'down-up' %>"></i>
                  </a>
                <% } %>
              </th>
              <th scope="col">
                <% if (isCurrent || isFuture) { %>
                  Paid
                <% } else { %>
                <a href="?sort=paid&order=<%= sort === 'paid' && order === 'asc' ? 'desc' : 'asc' %>" 
                  class="text-decoration-none <%= sort === 'paid' ? 'text-primary fw-semibold' : 'text-reset' %>">
                  Paid <i class="bi bi-arrow-<%= sort === 'paid' ? (order === 'asc' ? 'up' : 'down') : 'down-up' %>"></i>
                </a>
                <% } %>
              </th>
              <th scope="col" class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% rentals.forEach(function(rental) { %>
              <tr data-name="<%= rental.name || '' %>" data-address="<%= rental.address || '' %>">
                <%# Customer Info %>
                <td>
                  <div class="fw-semibold"><%= rental.name %></div>
                  <div class="text-muted small"><%= rental.organization %></div>
                  <div class="text-muted small">
                    <i class="bi bi-telephone me-1"></i><%= rental.phone %>
                  </div>
                </td>

                <%# Address & Placement %>
                <td class="text-wrap" style="max-width: 180px;">
                  <div><%= rental.address %></div>
                  <% if (rental.placement) { %>
                    <div class="text-muted small">
                      <i class="bi bi-geo-alt me-1"></i><%= rental.placement %>
                    </div>
                  <% } %>
                </td>

                <%# Dumpster Size %>
                <td>
                  <span class="badge bg-secondary"><%= rental.size %></span>
                </td>

                <%# Delivery Date %>
                <td>
                  <% if (rental.deliveryDate) { %>
                    <i class="bi bi-truck me-1 text-muted"></i><%= formatTableDate(rental.deliveryDate) %>
                  <% } else { %>
                    <span class="text-muted">—</span>
                  <% } %>
                </td>

                <%# Pickup Date %>
                <td>
                  <% if (rental.pickupDate) { %>
                    <i class="bi bi-calendar-check me-1 text-muted"></i><%= formatTableDate(rental.pickupDate) %>
                  <% } else { %>
                    <span class="text-muted">—</span>
                  <% } %>
                </td>

                <%# Status Badge %>
                <td>
                  <%
                    const statusMap = {
                      pending:   { cls: 'warning',   icon: 'clock',         label: 'Pending' },
                      active:    { cls: 'primary',   icon: 'play-circle',   label: 'Paid' },
                      completed: { cls: 'success',   icon: 'check-circle',  label: 'Completed' },
                      cancelled: { cls: 'danger',    icon: 'x-circle',      label: 'Cancelled' }
                    };
                    const s = statusMap[rental.status] || { cls: 'secondary', icon: 'question-circle', label: rental.status };
                  %>
                  <span class="badge text-bg-<%= s.cls %>">
                    <i class="bi bi-<%= s.icon %> me-1"></i><%= s.label %>
                  </span>
                </td>

                <%# Paid Badge %>
                <td>
                  <% if (rental.paid) { %>
                    <span class="badge text-bg-success">
                      <i class="bi bi-check-lg me-1"></i>Paid
                    </span>
                  <% } else { %>
                    <span class="badge text-bg-danger">
                      <i class="bi bi-x-lg me-1"></i>Unpaid
                    </span>
                  <% } %>
                </td>

                <%# Actions %>
                <td class="text-end">
                  <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
                    <a href="/rental/<%= rental.id %>/edit" class="btn btn-sm btn-outline-primary" title="Edit">
                      Edit
                    </a>
                  <% } %>
                </td>

              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>

</div>
<%- include('../partials/footer') %>
