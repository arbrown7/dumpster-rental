<%- include('../partials/header') %>
    <div class="bg-light confirmation-page">
        <div class="container py-5">
            <div class="row justify-content-center">
                <div class="col-12 col-lg-8">
                    <div class="card shadow-sm">
                        <div class="card-body p-4">
                            <h1 class="h3 mb-2">Dumpster Rental Updated</h1>
                            <p class="text-muted mb-4">
                                This rental has been changed.
                            </p>

                            <h3 class="h5 mt-4">Rental Summary</h3>
                            <ul class="list-group">
                                <li class="list-group-item d-flex justify-content-between align-items-start">
                                    <span>Dumpster Size</span>
                                    <strong>
                                        <%= data.size %>
                                    </strong>
                                </li>
                                <li class="list-group-item d-flex justify-content-between align-items-start">
                                    <span>Delivery Date</span>
                                    <strong>
                                        <%= data.deliveryDate %>
                                    </strong>
                                </li>
                                <li class="list-group-item d-flex justify-content-between align-items-start">
                                    <span>Pickup Date</span>
                                    <strong>
                                        <%= data.pickupDate %>
                                    </strong>
                                </li>
                                <li class="list-group-item d-flex justify-content-between align-items-start">
                                    <span>Address</span>
                                    <strong class="text-end">
                                        <%= data.address %>
                                    </strong>
                                </li>
                            </ul>

                            <a href="/rental" class="btn btn-outline-primary mt-4">Submit Another Request</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
<%- include('../partials/footer') %>