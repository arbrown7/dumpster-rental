<!DOCTYPE html>
<html>
<head>
    <title>Dumpster Rental Form</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="/bootstrap/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/main.css">
</head>
<body class="bg-light rental-form-page">
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h1 class="h3 mb-4">Draper City Dumpster Rental</h1>

                    <form action="/dumpster" method="POST" class="vstack gap-3">
                        <div>
                            <h2 class="h5">Dumpster Size</h2>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="size" id="size20" value="20 Yard" required>
                                <label class="form-check-label" for="size20">20 Yard ($120)</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="size" id="size30" value="30 Yard">
                                <label class="form-check-label" for="size30">30 Yard ($150)</label>
                            </div>
                        </div>

                        <div>
                            <h2 class="h5">Customer Information</h2>
                            <label class="form-label" for="name">Full Name</label>
                            <input class="form-control" type="text" id="name" name="name" required>

                            <label class="form-label mt-3" for="phone">Phone Number</label>
                            <input class="form-control" type="tel" id="phone" name="phone" required>

                            <label class="form-label mt-3" for="organization">Organization / Group</label>
                            <input class="form-control" type="text" id="organization" name="organization">

                            <label class="form-label mt-3" for="address">Delivery Address</label>
                            <input class="form-control" type="text" id="address" name="address" required>

                            <label class="form-label mt-3" for="placement">Placement Instructions</label>
                            <textarea class="form-control" id="placement" name="placement" rows="3"></textarea>
                        </div>

                        <div>
                            <h2 class="h5">Scheduling</h2>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label" for="deliveryDate">Delivery Date</label>
                                    <input class="form-control" type="date" id="deliveryDate" name="deliveryDate" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" for="pickupDate">Pickup Date</label>
                                    <input class="form-control" type="date" id="pickupDate" name="pickupDate" required>
                                </div>
                            </div>
                        </div>

                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="agreement" id="agreement" required>
                            <label class="form-check-label" for="agreement">I understand dumpster rules and liability terms.</label>
                        </div>

                        <button class="btn btn-primary" type="submit">Submit Request</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="/bootstrap/js/bootstrap.bundle.min.js"></script>
</body>
</html>
