<%- include('../partials/header') %>
<div class="container py-5">

  <div class="mb-5">
    <h2 class="fw-bold mb-1"><%= title %></h2>
    <p class="text-muted">Manage rentals and users</p>
  </div>

  <div class="row g-4">

    <div class="col-md-4">
      <a href="/rental/all" class="text-decoration-none">
        <div class="card border-0 shadow-sm h-100 text-center p-4 hover-card">
          <div class="card-body">
            <i class="bi bi-collection fs-1 text-primary mb-3 d-block"></i>
            <h5 class="fw-semibold">All Rentals</h5>
            <p class="text-muted small mb-0">View and manage every rental in the system</p>
          </div>
        </div>
      </a>
    </div>

    <div class="col-md-4">
      <a href="/rental/current" class="text-decoration-none">
        <div class="card border-0 shadow-sm h-100 text-center p-4 hover-card">
          <div class="card-body">
            <i class="bi bi-truck fs-1 text-success mb-3 d-block"></i>
            <h5 class="fw-semibold">Current Rentals</h5>
            <p class="text-muted small mb-0">View rentals that are active today</p>
          </div>
        </div>
      </a>
    </div>

    <div class="col-md-4">
      <a href="/admin/users" class="text-decoration-none">
        <div class="card border-0 shadow-sm h-100 text-center p-4 hover-card">
          <div class="card-body">
            <i class="bi bi-people fs-1 text-secondary mb-3 d-block"></i>
            <h5 class="fw-semibold">Users</h5>
            <p class="text-muted small mb-0">View and manage user accounts</p>
          </div>
        </div>
      </a>
    </div>

  </div>

</div>
<%- include('../partials/footer') %>