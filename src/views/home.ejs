<%- include('partials/header') %>
    <div>
        <%# ── HERO ── %>
            <section class="home-hero">
                <div class="container">
                    <div class="row align-items-center">
                        <div class="col-lg-7">
                            <p class="home-hero__label">Draper City &mdash; Dumpster Rental</p>
                            <h1 class="home-hero__title">
                                The easiest way to<br>schedule a dumpster.
                            </h1>
                            <p class="home-hero__sub">
                                Reserve a dumpster for your next cleanout, renovation, or project.
                                Available to Draper City residents &mdash; book in minutes.
                            </p>
                            <div class="home-hero__cta">
                                <a href="/rental" class="btn btn-primary px-4 py-2">Reserve a Dumpster</a>
                                <span class="home-hero__note">
                                    <i class="bi bi-calendar-check"></i> Mon &amp; Thu delivery
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <%# ── INFO CARDS ── %>
                <section class="home-info">
                    <div class="container">
                        <p class="home-section-label">Good to Know</p>
                        <h2 class="home-section-title">Before You Book</h2>
                        
                        <div class="row g-4">

                            <div class="col-sm-6 col-lg-3">
                                <div class="home-info-card">
                                    <div class="home-info-card__icon"><i class="bi bi-calendar-week"></i></div>
                                    <div class="home-info-card__title">Delivery Days</div>
                                    <p class="home-info-card__text">
                                        We deliver on <strong>Mondays and Thursdays</strong> only.
                                        Plan your project around these dates when booking.
                                    </p>
                                </div>
                            </div>

                            <div class="col-sm-6 col-lg-3">
                                <div class="home-info-card">
                                    <div class="home-info-card__icon"><i class="bi bi-clock"></i></div>
                                    <div class="home-info-card__title">Delivery Window</div>
                                    <p class="home-info-card__text">
                                        Dumpsters arrive between <strong>7am and 3pm</strong>.
                                        We can't guarantee a specific time within that window.
                                    </p>
                                </div>
                            </div>

                            <div class="col-sm-6 col-lg-3">
                                <div class="home-info-card">
                                    <div class="home-info-card__icon"><i class="bi bi-geo-alt"></i></div>
                                    <div class="home-info-card__title">Draper Residents Only</div>
                                    <p class="home-info-card__text">
                                        This service is for <strong>Draper City residents</strong> only.
                                        A valid Draper address is required at booking.
                                    </p>
                                </div>
                            </div>

                            <div class="col-sm-6 col-lg-3">
                                <div class="home-info-card">
                                    <div class="home-info-card__icon"><i class="bi bi-pin-map"></i></div>
                                    <div class="home-info-card__title">Placement</div>
                                    <p class="home-info-card__text">
                                        Provide placement instructions at checkout &mdash;
                                        driveway, side yard, or wherever works best for your project.
                                    </p>
                                </div>
                            </div>
                        </div>
                        <a href="/faq" class="text-decoration-none" style="color: var(--primary); font-weight: 500; font-size: 0.9rem;"><i class="bi bi-arrow-right me-1"></i>See all FAQs</a>
                    </div>
                    
                </section>

                <%# ── SIZES ── %>
                    <section class="home-sizes">
                        <div class="container">
                            <p class="home-section-label">Dumpster Sizes</p>
                            <h2 class="home-section-title">Pick Your Size</h2>
                            <div class="row g-4">

                                <div class="col-md-6">
                                    <div class="home-size-card">
                                        <div class="home-size-card__number">20</div>
                                        <div class="home-size-card__unit">Yard Dumpster</div>
                                        <div class="home-size-card__price">$120</div>
                                        <p class="home-size-card__desc">
                                            Great for medium cleanouts, garage purges, or small renovation debris.
                                            Fits in most standard driveways.
                                        </p>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="home-size-card">
                                        <div class="home-size-card__number">30</div>
                                        <div class="home-size-card__unit">Yard Dumpster</div>
                                        <div class="home-size-card__price">$150</div>
                                        <p class="home-size-card__desc">
                                            Ideal for larger projects, full room remodels, or significant
                                            yard cleanups. More capacity, same simple booking.
                                        </p>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </section>

                    <%# ── BOTTOM CTA ── %>
                        <section class="home-cta">
                            <div class="container">
                                <h2>Ready to get started?</h2>
                                <p>Book your dumpster in minutes. Available to Draper City residents.</p>
                                <a href="/rental" class="btn btn-primary px-4 py-2">Reserve a Dumpster</a>
                            </div>
                        </section>
    </div>
    <%- include('partials/footer') %>